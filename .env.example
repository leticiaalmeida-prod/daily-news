# Telegram — from @BotFather
TELEGRAM_BOT_TOKEN=

# Your chat ID. Message the bot /start (after deploying + running
# scripts/set_webhook.py) and it replies with your chat ID — copy that here
# so the scheduled daily digest knows where to send itself.
TELEGRAM_CHAT_ID=

# Verifies incoming Telegram webhook requests are genuinely from Telegram
# (X-Telegram-Bot-Api-Secret-Token header) rather than a spoofed POST to the
# public webhook URL. Generate one: `python3 -c "import secrets; print(secrets.token_urlsafe(32))"`
# Must match exactly what's passed to scripts/set_webhook.py and what's set
# in Vercel's project env vars.
TELEGRAM_WEBHOOK_SECRET=

# Verifies /api/cron requests are genuinely from Vercel Cron, not a random
# GET to the public URL. This is Vercel's own convention: set the SAME value
# as CRON_SECRET in Vercel's project env vars and it auto-sends
# `Authorization: Bearer <this>` on every cron invocation. Not read by
# bot/config.py (api/cron.py reads it directly via os.environ) — kept here
# only so the local value matches what you set in Vercel.
CRON_SECRET=

# NYT developer key — developer.nytimes.com, needs Article Search API +
# Top Stories API enabled on the app.
NYT_API_KEY=

# No key needed for crypto coverage — RSS feeds (CoinDesk, The Block,
# Blockworks) are public, see bot/rss.py. (Messari's News API turned out to
# be gated behind an Enterprise/sales tier even on a real signup key — RSS
# replaced it entirely, nothing to configure here.)

# LLM (agent loop + digest comprehension pipeline)
ANTHROPIC_API_KEY=

# Optional overrides
# NEWSBOT_MODEL=claude-haiku-4-5
# NEWSBOT_MODE=live          # "live" | "recorded" (recorded = $0, offline, synthesized NYT responses)

# The daily digest SCHEDULE (what time, what timezone) is NOT set here — it's
# configured directly in vercel.json's cron expression (UTC-only). See that
# file's comment for the current schedule and how to change it.
